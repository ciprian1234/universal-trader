    "deploy-eth-mainnet": "npx hardhat run --network eth_mainnet scripts/deploy-local.ts",
    "deploy-local-with-ignition-not-used": "npx hardhat ignition deploy ignition/modules/FlashArbitrage.js --network localhost",
    "simulate-trade": "npx hardhat run scripts/simulate-trade.ts --network localhost"
  },
