{
  "name": "universal-trader",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch ./src/main.ts",
    "start": "bun run ./src/main.ts",
    "test": "bun test",
    "lint": "bunx biome check src/",
    "format": "bunx biome format --write src/",
    "identify-venues": "bun run ./src/scripts/identify-venues.ts",
    "run-price-oracle": "bun run ./src/scripts/run-price-oracle.ts",
    "compute-init-code-hash": "bun run ./src/scripts/compute-init-code-hash.ts"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "hono": "^4.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}